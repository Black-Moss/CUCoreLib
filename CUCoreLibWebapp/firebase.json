{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/tools/**",
        "destination": "/index.html"
      },
      {
        "source": "!/@(robots.txt|sitemap.xml|api/**|docs/**)",
        "destination": "/index.html"
      }
    ]
  }
}
